{
  "name": "BETTING_AI - Automatización Completa",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger (8 AM)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 500]
    },
    {
      "parameters": {
        "command": "python3",
        "arguments": "/data/betting_ai/download_teams.py\n--auto",
        "executeInFolder": "/data/betting_ai"
      },
      "id": "download-teams",
      "name": "Descargar Equipos",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "command": "python3",
        "arguments": "/data/betting_ai/main_vision.py\n--auto\n--umbral 50",
        "executeInFolder": "/data/betting_ai"
      },
      "id": "run-analysis",
      "name": "Analizar Partidos",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [750, 300]
    },
    {
      "parameters": {
        "command": "python3",
        "arguments": "/data/betting_ai/test_hybrid.py\n--report",
        "executeInFolder": "/data/betting_ai"
      },
      "id": "generate-report",
      "name": "Generar Reporte",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "chatId": "TU_CHAT_ID",
        "text": "🤖 **BETTING_AI - Reporte Diario**\n\n📊 Fecha: {{$now.toFormat('dd/MM/yyyy')}}\n\n✅ Descarga de equipos completada\n✅ Análisis de partidos ejecutado\n✅ Parlays generados con umbral 50%\n\n📁 Ver resultados en /data/betting_ai/reports/"
      },
      "id": "telegram-notify",
      "name": "Telegram Notify",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1250, 300]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Descargar Equipos",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Schedule Trigger (8 AM)": {
      "main": [
        [
          {
            "node": "Descargar Equipos",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Descargar Equipos": {
      "main": [
        [
          {
            "node": "Analizar Partidos",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Analizar Partidos": {
      "main": [
        [
          {
            "node": "Generar Reporte",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generar Reporte": {
      "main": [
        [
          {
            "node": "Telegram Notify",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}

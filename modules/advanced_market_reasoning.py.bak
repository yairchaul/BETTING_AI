# modules/advanced_market_reasoning.py
"""
Motor avanzado de razonamiento de mercados
Versión corregida: NO sugiere Under 3.5 como opción principal
Prioriza mercados apostables (40-80% de probabilidad)
"""

class AdvancedMarketReasoning:

    def __init__(self):

        self.over_goal_threshold = 2.7
        self.under_goal_threshold = 2.2

        self.favorite_threshold = 0.60
        self.strong_favorite_threshold = 0.70
        
        # Mercados que NO queremos sugerir como principales
        self.banned_markets = ["Under 3.5", "Under 2.5", "Under 1.5"]

    # ---------------------------------------------------------
    # Detectar perfil del partido
    # ---------------------------------------------------------

    def detect_match_profile(self, simulation):

        avg_goals = simulation["avg_goals"]
        btts = simulation["btts"]

        if avg_goals >= self.over_goal_threshold:
            return "over_game"

        if avg_goals <= self.under_goal_threshold:
            return "under_game"

        if btts > 0.65:
            return "btts_game"

        return "balanced"

    # ---------------------------------------------------------
    # Detectar favorito
    # ---------------------------------------------------------

    def detect_favorite(self, simulation, home_team, away_team):

        home_prob = simulation["home"]
        away_prob = simulation["away"]

        if home_prob > self.strong_favorite_threshold:
            return f"Gana {home_team}", home_prob, "strong_home"

        if away_prob > self.strong_favorite_threshold:
            return f"Gana {away_team}", away_prob, "strong_away"

        if home_prob > self.favorite_threshold:
            return f"Gana {home_team}", home_prob, "home"

        if away_prob > self.favorite_threshold:
            return f"Gana {away_team}", away_prob, "away"

        return None, None, None

    # ---------------------------------------------------------
    # Generar mercados inteligentes (SIN UNDER 3.5)
    # ---------------------------------------------------------

    def generate_smart_markets(self, simulation, home_team, away_team):

        markets = []

        over15 = simulation["over15"]
        over25 = simulation["over25"]
        over35 = simulation["over35"]
        btts = simulation["btts"]

        home = simulation["home"]
        away = simulation["away"]

        avg_goals = simulation["avg_goals"]

        # Over markets - Solo si tienen probabilidad razonable
        if over15 > 0.60 and over15 < 0.95:
            markets.append(("Over 1.5", over15, "safe"))

        if over25 > 0.45 and over25 < 0.90:
            markets.append(("Over 2.5", over25, "medium"))

        if over35 > 0.35 and over35 < 0.85:
            markets.append(("Over 3.5", over35, "risky"))

        # BTTS
        if btts > 0.45 and btts < 0.85:
            markets.append(("BTTS Sí", btts, "medium"))

        # Favoritos - Solo si tienen probabilidad razonable
        if home > 0.55 and home < 0.85:
            markets.append((f"Gana {home_team}", home, "favorite"))

        if away > 0.55 and away < 0.85:
            markets.append((f"Gana {away_team}", away, "favorite"))

        # Combinados inteligentes - Solo si tienen sentido
        if home > 0.50 and over15 > 0.60:
            prob = min(home * 0.9, over15 * 0.9)  # Ajuste conservador
            if 0.40 < prob < 0.80:
                markets.append((f"{home_team} + Over 1.5", prob, "combo"))

        if away > 0.50 and over15 > 0.60:
            prob = min(away * 0.9, over15 * 0.9)
            if 0.40 < prob < 0.80:
                markets.append((f"{away_team} + Over 1.5", prob, "combo"))

        return markets

    # ---------------------------------------------------------
    # Score de confianza
    # ---------------------------------------------------------

    def score_market(self, market):

        name, prob, category = market

        stability_map = {
            "safe": 1.0,
            "favorite": 0.95,
            "medium": 0.90,
            "combo": 0.92,
            "risky": 0.80
        }

        stability = stability_map.get(category, 0.85)

        # Penalizar probabilidades extremas
        if prob > 0.85:
            stability *= 0.7  # Muy probable = cuota baja
        elif prob < 0.30:
            stability *= 0.5  # Muy improbable = riesgo alto

        score = prob * stability

        return {
            "market": name,
            "prob": prob,
            "category": category,
            "score": score
        }

    # ---------------------------------------------------------
    # Seleccionar mejor mercado
    # ---------------------------------------------------------

    def select_best_market(self, markets):

        if not markets:
            return None

        scored = [self.score_market(m) for m in markets]

        # Filtrar por probabilidad razonable (40-80%)
        filtered = [s for s in scored if 0.40 <= s['prob'] <= 0.80]

        if filtered:
            filtered.sort(key=lambda x: x["score"], reverse=True)
            return filtered[0]

        # Si no hay en rango 40-80%, tomar el mejor score general
        scored.sort(key=lambda x: x["score"], reverse=True)
        return scored[0] if scored else None

    # ---------------------------------------------------------
    # Análisis completo
    # ---------------------------------------------------------

    def analyze(self, simulation, home_team, away_team):

        profile = self.detect_match_profile(simulation)

        smart_markets = self.generate_smart_markets(
            simulation,
            home_team,
            away_team
        )

        best = self.select_best_market(smart_markets)

        return {
            "match_profile": profile,
            "candidate_markets": smart_markets,
            "best_pick": best
        }
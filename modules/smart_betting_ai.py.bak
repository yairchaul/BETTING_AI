"""
Cerebro central del sistema de apuestas
Combina Poisson, Monte Carlo, detección de value y ranking de mercados
"""

import numpy as np
from math import exp, factorial

SIMULATIONS = 10000
MAX_GOALS = 6


def poisson_prob(k, lam):
    """Probabilidad de Poisson P(X = k)"""
    return (exp(-lam) * lam**k) / factorial(k)


class SmartBettingAI:

    def __init__(self, league_avg_goals=2.6):

        self.league_avg_goals = league_avg_goals
        self.simulations = SIMULATIONS

        self.league_profiles = {
            "over_league": 2.9,
            "balanced": 2.6,
            "under_league": 2.3
        }

    # ---------------------------------------------------------
    # Expected Goals
    # ---------------------------------------------------------

    def expected_goals(self, home_stats, away_stats, league_type="balanced"):

        league_avg = self.league_profiles.get(league_type, self.league_avg_goals)

        home_attack = home_stats.get('attack', home_stats.get('avg_goals_scored', 1.2))
        home_defense = home_stats.get('defense', home_stats.get('avg_goals_conceded', 1.2))

        away_attack = away_stats.get('attack', away_stats.get('avg_goals_scored', 1.2))
        away_defense = away_stats.get('defense', away_stats.get('avg_goals_conceded', 1.2))

        home_attack_norm = home_attack / league_avg
        away_attack_norm = away_attack / league_avg

        home_defense_norm = home_defense / league_avg
        away_defense_norm = away_defense / league_avg

        lambda_home = (home_attack_norm * away_defense_norm) * (league_avg / 2)
        lambda_away = (away_attack_norm * home_defense_norm) * (league_avg / 2)

        return lambda_home, lambda_away

    # ---------------------------------------------------------
    # Monte Carlo
    # ---------------------------------------------------------

    def monte_carlo_match(self, lambda_home, lambda_away):

        results = {
            "home": 0,
            "draw": 0,
            "away": 0,
            "over15": 0,
            "over25": 0,
            "over35": 0,
            "btts": 0,
        }

        total_goals_list = []

        for _ in range(self.simulations):

            home_goals = np.random.poisson(lambda_home)
            away_goals = np.random.poisson(lambda_away)

            total = home_goals + away_goals
            total_goals_list.append(total)

            if home_goals > away_goals:
                results["home"] += 1
            elif home_goals == away_goals:
                results["draw"] += 1
            else:
                results["away"] += 1

            if total >= 2:
                results["over15"] += 1

            if total >= 3:
                results["over25"] += 1

            if total >= 4:
                results["over35"] += 1

            if home_goals > 0 and away_goals > 0:
                results["btts"] += 1

        for key in results:
            results[key] /= self.simulations

        results["avg_goals"] = np.mean(total_goals_list)
        results["std_goals"] = np.std(total_goals_list)

        return results

    # ---------------------------------------------------------
    # Ranking mercados
    # ---------------------------------------------------------

    def rank_markets(self, simulation, home_team, away_team):

        markets = [
            ("Over 1.5", simulation["over15"]),
            ("Over 2.5", simulation["over25"]),
            ("Over 3.5", simulation["over35"]),
            ("BTTS Sí", simulation["btts"]),
            (f"Gana {home_team}", simulation["home"]),
            ("Empate", simulation["draw"]),
            (f"Gana {away_team}", simulation["away"])
        ]

        markets.sort(key=lambda x: x[1], reverse=True)

        return markets

    # ---------------------------------------------------------
    # Value bet
    # ---------------------------------------------------------

    def detect_value(self, prob, bookmaker_odds):

        value = prob * bookmaker_odds
        ev = value - 1

        return value, ev

    # ---------------------------------------------------------
    # Selección de mejor apuesta
    # ---------------------------------------------------------

    def select_best_bet(self, markets):

        market_dict = {name: prob for name, prob in markets}

        # Regla especial Over1.5
        if market_dict.get("Over 1.5", 0) > 0.80:
            return "Over 1.5", market_dict["Over 1.5"]

        strong = [(m, p) for m, p in markets if p > 0.65]

        if strong:
            return strong[0]

        medium = [(m, p) for m, p in markets if p > 0.55]

        if medium:
            return medium[0]

        return markets[0]

    # ---------------------------------------------------------
    # Análisis completo
    # ---------------------------------------------------------

    def analyze_match(self, home_team, away_team, home_stats, away_stats,
                      bookmaker_odds=None, league_type="balanced"):

        lambda_home, lambda_away = self.expected_goals(
            home_stats,
            away_stats,
            league_type
        )

        simulation = self.monte_carlo_match(lambda_home, lambda_away)

        ranked_markets = self.rank_markets(simulation, home_team, away_team)

        best_market, best_prob = self.select_best_bet(ranked_markets)

        fair_odds = 1 / best_prob if best_prob > 0 else 2.0

        suggested_odds = fair_odds * 0.95

        value_info = {}

        if bookmaker_odds:

            odds_map = {
                f"Gana {home_team}": bookmaker_odds.get('local', fair_odds),
                "Empate": bookmaker_odds.get('draw', fair_odds),
                f"Gana {away_team}": bookmaker_odds.get('visitante', fair_odds),
                "Over 1.5": bookmaker_odds.get('over15', fair_odds),
                "Over 2.5": bookmaker_odds.get('over25', fair_odds),
                "BTTS Sí": bookmaker_odds.get('btts', fair_odds)
            }

            market_odds = odds_map.get(best_market, fair_odds)

            value, ev = self.detect_value(best_prob, market_odds)

            value_info = {
                "market_odds": market_odds,
                "value": value,
                "ev": ev
            }

        return {
            "home_team": home_team,
            "away_team": away_team,
            "lambda_home": lambda_home,
            "lambda_away": lambda_away,
            "simulation": simulation,
            "ranked_markets": ranked_markets,
            "best_market": best_market,
            "best_prob": best_prob,
            "fair_odds": fair_odds,
            "suggested_odds": suggested_odds,
            "value_info": value_info
        }